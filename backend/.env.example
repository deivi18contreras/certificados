# Configuración del Servidor
PORT=4000
NODE_ENV=development

# Base de Datos
MONGODB_URI=mongodb://localhost:27017/certificados_sena

# Seguridad
JWT_SECRET=cambiar_por_una_clave_segura_en_produccion

# Google Drive API (Para subida de PDF)
GOOGLE_DRIVE_CLIENT_ID=tu_cliente_id.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=tu_cliente_secreto
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:4000/api/reportes/drive/callback

# 2Captcha (Para resolución de captchas)
TWO_CAPTCHA_API_KEY=tu_api_key_de_2captcha

# Correo (Nodemailer - Opcional para notificaciones)
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_password_de_aplicacion
