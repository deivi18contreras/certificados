# Configuración del Servidor
PORT=4000
NODE_ENV=development

# Base de Datos
MONGODB_URI=mongodb://localhost:27017/certificados_sena

# Seguridad (JWT)
JWT_SECRET=tu_secret_key_segura_aqui

# Configuración de Google Drive API (OAuth2)
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/supervisors/google/callback

# 2Captcha API Key para resolver reCAPTCHA
TWO_CAPTCHA_API_KEY=tu_2captcha_api_key

# URL del Frontend (para redirecciones de OAuth)
FRONTEND_URL=http://localhost:5173

# Playwright: usar true en servidores sin display, false para depuración local
HEADLESS=false
